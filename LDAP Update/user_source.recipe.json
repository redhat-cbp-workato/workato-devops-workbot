          {
            "number": 3,
            "provider": "py_eval",
            "name": "invoke_custom_py_code",
            "as": "c0ec0854",
            "keyword": "action",
            "input": {
              "code": "import csv\nfrom io import StringIO\n\ndef main(code_input):\n\n    csv_text = code_input.get(\"input_data\")\n\n    if not csv_text:\n        return {\"records\": [], \"count\": 0}\n\n    # Clean BOM if present\n    csv_text = csv_text.lstrip('\\ufeff')\n\n    f = StringIO(csv_text)\n\n    reader = csv.reader(f, delimiter=',', quotechar='\"')\n\n    records = []\n\n    for row in reader:\n        # Skip empty or broken rows\n        if not row or len(row) < 1:\n            continue\n\n        try:\n            records.append({\n                \"Id\": row[0] if len(row) > 0 else \"\",\n                \"Title\": row[1] if len(row) > 1 else \"\",\n                \"ManagerId\": row[2] if len(row) > 2 else \"\",\n                \"Red_Hat_UUID__c\": row[3] if len(row) > 3 else \"\",\n                \"Business_Card_Title__c\": row[4] if len(row) > 4 else \"\",\n                \"EmployeeNumber\": row[5] if len(row) > 5 else \"\",\n                \"CountryCode\": row[6] if len(row) > 6 else \"\",\n                \"Email\": row[7] if len(row) > 7 else \"\"\n            })\n        except Exception as e:\n            # Skip bad rows instead of failing everything\n            continue\n\n    return {\n        \"records\": records,\n        \"count\": len(records)\n    }",
              "name": "sfusersdata",
              "code_input": {
                "schema": "[{\"name\":\"input_data\",\"type\":\"string\",\"optional\":true,\"label\":\"input_data\",\"details\":{\"real_name\":\"input_data\"},\"control_type\":\"text\",\"parent\":[\"code_input\",\"data\"]}]",
                "data": {
                  "input_data": "#{_dp('{\"pill_type\":\"output\",\"provider\":\"salesforce\",\"line\":\"78247955\",\"path\":[\"results\"]}')}"
                }
              },
              "code_output_schema_json": "[{\"label\":\"Records\",\"of\":\"object\",\"properties\":[{\"control_type\":\"text\",\"label\":\"ID\",\"type\":\"string\",\"name\":\"Id\"},{\"control_type\":\"text\",\"label\":\"Title\",\"type\":\"string\",\"name\":\"Title\"},{\"control_type\":\"text\",\"label\":\"Manager ID\",\"type\":\"string\",\"name\":\"ManagerId\"},{\"control_type\":\"text\",\"label\":\"Red hat UUID c\",\"type\":\"string\",\"name\":\"Red_Hat_UUID__c\"},{\"control_type\":\"text\",\"label\":\"Business card title c\",\"type\":\"string\",\"name\":\"Business_Card_Title__c\"},{\"control_type\":\"text\",\"label\":\"Employee number\",\"type\":\"string\",\"name\":\"EmployeeNumber\"},{\"control_type\":\"text\",\"label\":\"Country code\",\"type\":\"string\",\"name\":\"CountryCode\"},{\"control_type\":\"text\",\"label\":\"Email\",\"type\":\"string\",\"name\":\"Email\"}],\"type\":\"array\",\"name\":\"records\"},{\"control_type\":\"number\",\"label\":\"Count\",\"parse_output\":\"float_conversion\",\"type\":\"number\",\"name\":\"count\"}]"
            },
