      {
        "number": 1,
        "provider": "oracle",
        "name": "search_rows_sql",
        "as": "f853d7d1",
        "keyword": "action",
        "input": {
          "sql": "SELECT \nXXRHSIAS.INTERFACE_ID INTERFACE_ID,\nXXRHSIAS.COUNTRY COUNTRY,\nVENDOR_SITE_CODE VENDOR_SITE_CODE,\nAPS.VENDOR_ID ORACLE_VENDOR_ID, \nCASE \n        WHEN XXRHSIAS.INTERFACE_STATUS = 'C' THEN 'Fully Integrated'\n        WHEN XXRHSIAS.INTERFACE_STATUS = 'E' THEN 'Partially Integrated'\n        WHEN XXRHSIAS.INTERFACE_STATUS = 'F' THEN 'Not Integrated'\n        ELSE 'Status Unknown'\n    END AS INTERFACE_STATUS,\nXXRHSIAS.INTERFACE_ERROR INTERFACE_ERROR,\nXXRHSIAS.LAST_UPDATED_DATE LAST_UPDATED_DATE,\nXXRHSIAS.INACTIVE_DATE INACTIVE_DATE,\nXXRHSIAS.LAST_UPDATED_BY LAST_UPDATED_BY,\nXXRHSIAS.OU_NAME OU_NAME,\nXXRHSIAS.VENDOR_NAME VENDOR_NAME,\nXXRHSIAS.CATEGORY1 CATEGORY1,\nXXRHSIAS.PIF_SUPPLIER PIF_SUPPLIER,\nXXRHSIAS.PIF_VALIDATION_EXPIRATION_DATE PIF_VALIDATION_EXPIRATION_DATE,\nXXRHSIAS.ARIBA_VENDOR_ID ARIBA_VENDOR_ID,\nXXRHSIAS.SNOW_TICKET_NUMBER SNOW_TICKET_NUMBER,\nXXRHSIAS.TAX_REG_NUM TAX_REG_NUM,\nXXRHSIAS.TAX_PAYER_ID TAX_PAYER_ID,\nXXRHSIAS.DUNS_NUMBER DUNS_NUMBER\nFROM XXRHFIN.XXRH_SUPPLIER_IMPORT_ALTER_STG XXRHSIAS, APPS.AP_SUPPLIERS APS\nWHERE XXRHSIAS.ARIBA_VENDOR_ID = APS.GLOBAL_ATTRIBUTE14\nAND (XXRHSIAS.LAST_UPDATED_DATE) >= (SYSDATE - :no_of_days)",
          "parameters": {
            "schema": "[{\"name\":\"no_of_days\",\"type\":\"number\",\"optional\":true,\"label\":\"no_of_days\",\"details\":{\"real_name\":\"no_of_days\"},\"control_type\":\"number\",\"parent\":[\"parameters\",\"data\"]}]",
            "data": {
              "no_of_days": "1"
            }
          },
          "orderby": "INTERFACE_ID",
          "output_schema": "[{\"control_type\":\"number\",\"label\":\"Interface ID\",\"parse_output\":\"float_conversion\",\"type\":\"number\",\"name\":\"interface_id\"},{\"control_type\":\"text\",\"label\":\"Country\",\"type\":\"string\",\"name\":\"country\"},{\"control_type\":\"text\",\"label\":\"Vendor site code\",\"type\":\"string\",\"name\":\"vendor_site_code\"},{\"control_type\":\"number\",\"label\":\"Oracle vendor ID\",\"parse_output\":\"float_conversion\",\"type\":\"number\",\"name\":\"oracle_vendor_id\"},{\"control_type\":\"text\",\"label\":\"Interface status\",\"type\":\"string\",\"name\":\"interface_status\"},{\"control_type\":\"text\",\"label\":\"Interface error\",\"type\":\"string\",\"name\":\"interface_error\"},{\"control_type\":\"text\",\"label\":\"Last updated date\",\"render_input\":\"date_time_conversion\",\"parse_output\":\"date_time_conversion\",\"type\":\"date_time\",\"name\":\"last_updated_date\"},{\"control_type\":\"text\",\"label\":\"Inactive date\",\"type\":\"string\",\"name\":\"inactive_date\"},{\"control_type\":\"number\",\"label\":\"Last updated by\",\"parse_output\":\"float_conversion\",\"type\":\"number\",\"name\":\"last_updated_by\"},{\"control_type\":\"text\",\"label\":\"Ou name\",\"type\":\"string\",\"name\":\"ou_name\"},{\"control_type\":\"text\",\"label\":\"Vendor name\",\"type\":\"string\",\"name\":\"vendor_name\"},{\"control_type\":\"text\",\"label\":\"Category 1\",\"type\":\"string\",\"name\":\"category1\"},{\"control_type\":\"text\",\"label\":\"Pif supplier\",\"type\":\"string\",\"name\":\"pif_supplier\"},{\"control_type\":\"text\",\"label\":\"Pif validation expiration date\",\"type\":\"string\",\"name\":\"pif_validation_expiration_date\"},{\"control_type\":\"text\",\"label\":\"Ariba vendor ID\",\"type\":\"string\",\"name\":\"ariba_vendor_id\"},{\"control_type\":\"text\",\"label\":\"Snow ticket number\",\"type\":\"string\",\"name\":\"snow_ticket_number\"},{\"control_type\":\"text\",\"label\":\"Tax reg num\",\"type\":\"string\",\"name\":\"tax_reg_num\"},{\"control_type\":\"text\",\"label\":\"Tax payer ID\",\"type\":\"string\",\"name\":\"tax_payer_id\"},{\"control_type\":\"text\",\"label\":\"Duns number\",\"type\":\"string\",\"name\":\"duns_number\"}]"
